Question  = code of geeksfor geeks problem like max sum subarray of size k


class Solution {
  public:
    int maxSubarraySum(vector<int>& arr, int k) {
        // code here
        int i = 0;//Window shrink
        int j = 0;//Window Grow
        int curr_sum = 0;
        int max_sum = INT_MIN;
        int n = arr.size();
        while(j<n)
        {
            curr_sum = curr_sum + arr[j];
            if(j-i+1< k)
            {
                j++;
            }
            else if(j-i+1 == k)
            {
                max_sum = max(max_sum,curr_sum);
                curr_sum = curr_sum - arr[i];
                i++;
                j++;
            }
        }
        return max_sum;
        
    }
};


Question = allocate minimum pages of geeksforgeeks problem

class Solution {
  public:
  bool ispossible(vector<int> &arr, int k, int mid )
  {
     int student = 1;
     int readpages = 0;
     for(int i = 0;i<arr.size();)
     {
         if((readpages + arr[i]) <= mid)
         {
             readpages += arr[i];
             i++;
         }
         else
         {
             student++;
             readpages = 0;
         }
         if(student > k)
         {
             return false;
         }
     }
     return true;
  }
    int findPages(vector<int> &arr, int k) {
       if(k > arr.size())
       {
           return -1;
       }
       int total = 0;
       int ans;
       for(int i = 0;i<arr.size();i++)
       {
           total += arr[i];
       }
       int s = 1, e = total;
       while(s<=e)
       {
           int mid = (s+e)/2; // at most mid capacity of a person to read pages
           if(ispossible(arr,k,mid))
           {
               ans = mid;
               e = mid - 1;
           }
           else
           {
               s = mid + 1;
           }
        
        }
        return ans;
    }    
};

