        int s = 1, e = stalls[n-1] - stalls[0];
        int ans;
        while(s<=e)
        {
            int mid = (s+e)/2;
            if(ispossible(stalls,k,mid))
            {
                ans  = mid;
                s =  mid + 1;
            }
            else
            {
                e = mid - 1;
            }
        }
        return ans;
        
    }
};

Question = code for problem 367 of leetcode


class Solution {
public:
    bool isPerfectSquare(int num) {
        long long s = 1,e = num;
        while(s<=e)
        {
            long long mid = (s+e)/2;
            if(mid * mid == num)
            {
               return true;
            }
            else if(mid * mid > num)
            {
                e = mid - 1;
            }
            else
            {
                s = mid + 1;
            }
        }
        return false;
    }
}; 
