#include <iostream>
using namespace std;
//Encapsulation/Abstraction
class Student
{
  private:
  string name;
  int age;
  int roll_no;
  
  public:
  void setter(string n,int a, int r)
  {
    name = n;
    age = a;
    roll_no = r;
  }
  
  int getter()
  {
    return age;
    
  }
};


int main() 
{
  Student obj;
  obj.setter("Aman",20,10);
  cout<<obj.getter();

  return 0;
}




