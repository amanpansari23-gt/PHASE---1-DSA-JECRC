Question = code of sum of digits for geeksforgeeks


class Solution {
    void solve(int n,int &sum)
    {
        //Base case
        if(n==0)
        {
            return;
        }
        
        //Recursive case
        int rem = n%10;//Last digit
        sum = sum + rem;
        solve(n/10,sum);
    }
  public:
    int sumOfDigits(int n) {
        // code here
        int sum = 0;
        solve(n,sum);
        return sum;
    }
};


Question = code for factorial using recursion gfg


class Solution {
    int fact(int n)
    {
        //base case
        if(n==0)
        return 1;
        
        //Recursive case 
        return n*fact(n-1);
    }
  public:
    int factorial(int n) {
        // code here
        return fact(n);
    }
};

Question = code for binary search using recursion



#include <iostream>
using namespace std;
//Binary search using Recursion
bool binarySearch(int arr[],int target, int s,int e)
{
  //base case
  if(s>e)
  {
    return false;
  }
  
  int mid = (s+e)/2;
  if(arr[mid] == target)
  {
    return true;
  }
  else if(arr[mid]>target)
  {
    return binarySearch(arr,target,s,mid-1);
  }
  else
  {
    return binarySearch(arr,target,mid+1,e);
  }
}
int main() 
{
   int arr[6] = {1,2,3,4,5,6};
   int n=6;
   int target = 5;
   if(binarySearch(arr,target,0,n-1) == true)
   {
     cout<<"present";
   }
   else
   {
     cout<<"Absent";
   }
   
   return 0 ;
}

Question = code for reverse array using recursion 


#include <iostream>
using namespace std;

void reverse(int arr[],int i,int j)
{
  //base case
  if(i>j)
  {
    return;
  }
  ///recursive case
  swap(arr[i],arr[j]);
  
  reverse(arr,i+1,j-1);
}
int main() 
{
  int arr[6] = {1,2,3,4,5,6};
  int n= 6;
  reverse(arr,0,n-1);
  
  for(int i = 0; i < n;i++)
  {
    cout<<arr[i]<<" ";
  }
  return 0;
}
