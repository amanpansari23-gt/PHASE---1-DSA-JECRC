class Solution {
  public:
    Node *insertAtFront(Node *head, int x) {
      Node* n = new Node(x);
      if(head == NULL)
      {
          head = n;
      }else{
          Node* n = new Node(x);
          Node* temp  = head;
          n->next = temp;
          head = n;
      }
      return head;
      
    }
};
