class Solution {
  public:
    Node *insertAtEnd(Node *head, int x) {
       if(head == NULL)
       {
           Node *n = new Node(x);
           head = n;
       }
       else{
           Node *n = new Node(x);
           Node *temp = head;
           while(temp->next != NULL)
           temp = temp->next;
           temp->next = n;
       }
       return head;
    }
};
