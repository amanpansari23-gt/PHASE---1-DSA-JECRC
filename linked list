Question = code for deletion at the end in linked list of gfg

/*
class Node {
public:
    int data;
    Node* next;

    Node(int x) {
        data = x;
        next = NULL;
    }
};
*/
class Solution {
  public:
    Node* removeLastNode(Node* head) {
        if(head == NULL)
        return NULL;
        else if(head->next == NULL){
            delete head;
            head = NULL;
        }
        else{
            Node *temp = head;
            while(temp->next->next != NULL)
            temp = temp->next;
            delete(temp->next);
            temp->next = NULL;
        }
        return head;
    }
};


