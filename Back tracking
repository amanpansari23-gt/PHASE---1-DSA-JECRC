class Solution {
public:
    int fib(int n) {
        if(n == 0)
        return 0;

        if(n == 1)
        return 1;

         return fib(n-1)+fib(n-2);
    }
};


Question = problem 78 leetcode

class Solution {
public:
    void solve(vector<int>&nums,int i, vector<int>temp, vector<vector<int>>&output)
    {
        //base case
        if(i == nums.size())
        {
            output.push_back(temp);
            return;
        }

        //ignore ith element
        solve(nums,i+1,temp,output);

        //accept ith element
        int element = nums[i];
        temp.push_back(element);
        solve(nums,i+1,temp,output);
    }
    vector<vector<int>> subsets(vector<int>& nums) {
        vector<vector<int>> output;
        vector<int> temp;

        solve(nums,0,temp,output);
        return output;
    }
};

Question = problem 39 leetcode

class Solution {
public:
    void solve(vector<int> &candidates,int i,int target,vector<int>temp, vector<vector<int>> &output)
    {
        //base case
        if(target == 0)
        {
            output.push_back(temp);
            return;
        }

        if(i == candidates.size() || target < 0)
        return;

        if(candidates[i] <= target)
        {
            temp.push_back(candidates[i]);
            solve(candidates,i,target-candidates[i],temp,output);
            temp.pop_back();
        }
        solve (candidates,i+1,target,temp,output);

        
    }
    vector<vector<int>> combinationSum(vector<int>& candidates, int target) {
        vector<vector<int>> output;
        vector<int>temp;

        solve(candidates,0, target,temp,output);
        return output;
    }
};

Question = problem 70 leetcode

class Solution {
public:
    int solve(int n, int t[46])
    {
        if(n == 0 || n == 1)
        return 1;

        if(t[n] != -1)
        return t[n];

         t[n] = solve(n-1,t) + solve(n-2,t);
         return t[n];

    }
    int climbStairs(int n) {
        int t[46];
        memset(t,-1,sizeof(t));
        return solve(n,t);
        
    }
};
