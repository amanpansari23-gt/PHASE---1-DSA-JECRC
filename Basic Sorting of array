Question = code of bubble sort


#include <iostream>
using namespace std;
//Bubble sort O(n^2)

int main() 
{
    int arr[5] = {5,4,3,2,1};
    int n = 5;
    for(int i = 0;i<=n-1;i++)
    {
      for(int j = 0;j<=n-2;j++)
      {
        if(arr[j]>arr[j+1])
        {
          swap(arr[j],arr[j+1]);
        }
      }
    }
    
    //display sorted array
    for(int i = 0;i<=n-1;i++)
    {
      cout<<arr[i]<<" ";
    }
    
    return 0;
}


Question = code of insertion sort


#include <iostream>
using namespace std;
//Insertion sort O(n^2)

int main() 
{
    int arr[5] = {5,4,3,2,1};
    int n = 5;
    for(int i = 1;i<=n-1;i++)
    {
      for(int j = i;j>0;j--)
      {
        if(arr[j]<arr[j-1])
        {
          swap(arr[j],arr[j-1]);
        }
      }
    }
    
    //display sorted array
    for(int i = 0;i<=n-1;i++)
    {
      cout<<arr[i]<<" ";
    }
    
    return 0;
}


Question = code for selection sort


#include <iostream>
using namespace std;
//Selection sort O(n^2)

int main() 
{
    int arr[5] = {10,9,8,7,6};
    int n = 5;
    for(int i = 0;i<=n-1;i++)
    {
      int min_ele_index = i;
      for(int j = i+1;j<=n-1;j++)
      {
        if(arr[j]<arr[min_ele_index])
        {
          min_ele_index = j;
        }
      }
      
      swap(arr[i],arr[min_ele_index]);
    }
    
    //display sorted array
    for(int i = 0;i<=n-1;i++)
    {
      cout<<arr[i]<<" ";
    }
    
    return 0;
}

Question = code for reverese array of geeks for geeks platform

class Solution {
  public:
    void reverseArray(vector<int> &arr) {
        // code here
        int n = arr.size();
        int i=0, j=n-1;
        while(i<=j)
        {
            swap(arr[i],arr[j]);
            i++;
            j--;
        }
    }
};


