Question = code for kth smallest gfg

class Solution {
  public:
    int kthSmallest(vector<int> &arr, int k) {
        //max heap
        priority_queue<int> max_heap;
        
        for(int i = 0;i<arr.size();i++)
        {
            max_heap.push(arr[i]);
            if(max_heap.size() > k)
            {
                max_heap.pop();
            }
            
        }
        return max_heap.top();
    }
};

