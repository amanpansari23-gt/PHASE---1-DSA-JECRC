class twoStacks {
  public:
  int *arr;
  int i;
  int j;
  int size;

    twoStacks() {
        size = 100;
        i = -1;
        j = size;
        arr = new int[size]; //dynamic array
    }

    // Function to push an integer into the stack1.
    void push1(int x) {
        if(i+1 != j)
        {
            i++;
            arr[i] = x;
        }
        
    }

    // Function to push an integer into the stack2.
    void push2(int x) {
        if(j-1 != i)
        {
            j--;
            arr[j] = x;
        }
    }

    // Function to remove an element from top of the stack1.
        
    int pop1() {
        //stack 1 empty
        if(i==-1)
        return -1;
        
        int x = arr[i];
        i--;
        return x;
    }

        
    // Function to remove an element from top of the stack2.
    int pop2() {
        // stack 2 empty
        if(j== size)
        return -1;
        
        int x = arr[j];
        j++;
        return x;
    }
};

Questiion = previous smaller element for gfg

class Solution {
  public:
    vector<int> prevSmaller(vector<int>& arr) {
        vector<int> output;
        
        stack<int> st;
        for(int i = 0;i<arr.size();i++)
        {
            if(st.empty())//this is your first element
            {
                output.push_back(-1);
            }
            else if(!st.empty() && st.top() < arr[i])
            {
                output.push_back(st.top());
            }
            else 
            {
                while(!st.empty() && st.top() >= arr[i])
                {
                    st.pop();
                }
                if(st.empty())
                {
                    output.push_back(-1);
                }
                else if(!st.empty() && st.top() <= arr[i])
                {
                    output.push_back(st.top());
                }
            }
            st.push(arr[i]);
        }
        return output;
    }
};

Question = code for problem 155 leetcode

class MinStack {
public:
    stack<int> st1;// all elements insert
    stack<int> st2;// only  abhi tak ka minimum
    
    MinStack() {
            }
    
    void push(int value) {
        if(st1.size()==0)
        {
            st1.push(value);
            st2.push(value);
        }
        else
        {
            st1.push(value);
            if(value <= st2.top())
            {
                st2.push(value);
            }
        }        
    }
    
    void pop() {
        if(st1.size()==0)
        return;

        int ans = st1.top();
        if(ans == st2.top())
        {
            st2.pop();
        }
        st1.pop();
    }
    
    int top() {
        if(st1.size()==0)
        return -1;

        return st1.top();
    }
    
    int getMin() {
        if(st2.size()==0)
        return -1;

        return st2.top();
        
    }
};

