    vector<int> rightSideView(TreeNode* root) {
        vector<int>ans;

        if(root == NULL)
        return ans;

        queue<TreeNode*> q;
        q.push(root);

        while(!q.empty())
        {
            int n = q.size();//uss particular level me kitne node h
            ans.push_back(q.front()->val);
            
            while(n>0)
            {
                TreeNode *temp = q.front();
                q.pop();
                

                if(temp -> right != NULL)
